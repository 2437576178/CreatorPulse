# CreatorPulse local development configuration.
# Copy this file to .env and fill your local values. Do not commit .env.

CREATORPULSE_DATA_SOURCE=mock
CREATORPULSE_SECRET_KEY=replace-with-a-long-random-local-secret

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=creatorpulse
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password

# Used later when Spark writes MySQL through JDBC.
SPARK_MYSQL_JDBC_URL=jdbc:mysql://127.0.0.1:3306/creatorpulse
SPARK_MYSQL_USER=your_user
SPARK_MYSQL_PASSWORD=your_password
SPARK_MYSQL_DRIVER=com.mysql.cj.jdbc.Driver
SPARK_MYSQL_WRITE_MODE=append
# Keep live Spark JDBC tests opt-in so normal verification never writes MySQL.
CREATORPULSE_RUN_SPARK_JDBC_LIVE=0

# Used later for the VM Kafka connectivity phase.
KAFKA_BOOTSTRAP_SERVERS=192.168.56.10:9092
KAFKA_TEST_TIMEOUT_SECONDS=5
CREATORPULSE_RUN_KAFKA_LIVE=0
SPARK_STREAM_TRIGGER_SECONDS=30
SPARK_STREAM_CHECKPOINT_DIR=./spark_jobs/checkpoints
SPARK_STREAM_OUTPUT_MODE=update
# Keep full Kafka -> Spark -> MySQL streaming opt-in because it is long-running and writes MySQL.
CREATORPULSE_RUN_FULL_PIPELINE_LIVE=0
