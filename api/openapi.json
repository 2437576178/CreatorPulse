  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "status",
          "schemaVersion",
          "generatedAt",
          "counts"
        ],
        "properties": {}
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "error"
        ],
        "properties": {}
      },
      "StatusResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "AuthUser": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "userId",
          "creatorId",
          "email",
          "displayName",
          "role"
        ],
        "properties": {
          "userId": {
            "type": "string"
          },
          "creatorId": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "displayName": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "AuthUserResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "user"
        ],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/AuthUser"
          }
        }
      },
      "Meta": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "schemaVersion",
          "generatedAt"
        ],
        "properties": {}
      },
      "Creator": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "creatorId",
          "displayName",
          "nicheTags",
          "timezone"
        ],
        "properties": {}
      },
      "Insight": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "insightId",
          "creatorId",
          "type",
          "scope",
          "targetId",
          "title",
          "summary",
          "priority",
          "evidenceMetrics",
          "recommendedActions",
          "generatedBy",
          "pageTargets"
        ],
        "properties": {
          "insightId": {
            "type": "string"
          },
          "generatedBy": {
            "type": "string",
            "enum": [
              "RULE_ENGINE",
              "SPARK_RULE_ENGINE"
            ]
          },
          "pageTargets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidenceMetrics": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "recommendedActions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "PageResponseBase": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "meta",
          "creator",
          "data"
        ],
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "creator": {
            "$ref": "#/components/schemas/Creator"
          }
        }
      },
      "growthDashboard": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "currentSnapshot",
          "topVideos",
          "insights"
        ],
        "properties": {
          "currentSnapshot": {
            "type": "object"
          },
          "topVideos": {
            "type": "array",
            "items": {
              "type": "object"
